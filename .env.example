# Stripe Payment Links for the Upgrade modal. Create these in the Stripe Dashboard
# (Payment Links > New) — one per price (Monthly, Yearly, Lifetime). No secret keys
# needed here; Payment Link URLs are public checkout pages.
#
# In each Payment Link's "After payment" settings, set the confirmation redirect to
# this app's deployed URL with `?upgraded=1` appended, e.g.:
#   https://your-quest-log-app.example.com/?upgraded=1
# That's what tells the app the purchase went through.

VITE_STRIPE_LINK_MONTHLY=
VITE_STRIPE_LINK_YEARLY=
VITE_STRIPE_LINK_LIFETIME=

# Cloud Sync — Supabase project (Dashboard > Project Settings > API). Both are safe to
# expose client-side; the anon key only grants what Row Level Security allows (see
# supabase/schema.sql), which is "each user can read/write their own row, nothing else."
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Cloud Sync — server-only secrets, used exclusively by api/stripe-webhook.js. NEVER
# prefix these with VITE_ (that would ship them to the browser) and never commit real
# values.
#
# STRIPE_SECRET_KEY: Stripe Dashboard > Developers > API keys (the secret key, not the
#   publishable one).
# STRIPE_WEBHOOK_SECRET: created when you add the webhook endpoint at Stripe Dashboard >
#   Developers > Webhooks > Add endpoint, pointed at
#   https://your-quest-log-app.example.com/api/stripe-webhook, listening for
#   `checkout.session.completed` and `customer.subscription.deleted`.
# SUPABASE_SERVICE_ROLE_KEY: Supabase Dashboard > Project Settings > API > service_role
#   key. This bypasses Row Level Security — it's what lets the webhook write premium
#   status even though regular users can't.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SUPABASE_SERVICE_ROLE_KEY=
